# Supabase (server-side only — never expose service role to client)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_NEVER_EXPOSE_TO_CLIENT

# Admin gate (coming-soon access control)
# Generate ADMIN_PASSWORD_HASH with: node scripts/hash-password.mjs
# Generate AUTH_SECRET with: openssl rand -hex 32
ADMIN_EMAIL=admin@example.com
# IMPORTANT: escape every `$` in the bcrypt hash with a backslash (\$).
# Vite's env loader will otherwise try to interpolate them as variables
# and silently drop the value.
#   Generated:  $2b$12$abc...
#   In .env:    ADMIN_PASSWORD_HASH=\$2b\$12\$abc...
ADMIN_PASSWORD_HASH=replace_with_escaped_bcrypt_hash
AUTH_SECRET=replace_with_32_byte_hex

# Email-at-rest encryption (AES-256-GCM)
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex chars (32 bytes). Losing this key means losing all
# stored emails — back it up like a treasure.
EMAIL_ENCRYPTION_KEY=replace_with_32_byte_hex
