{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "astro: dev",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": {
        "owner": "astro",
        "pattern": [
          {
            "regexp": "^.*$",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*astro.*",
          "endsPattern": ".*Local:.*localhost.*"
        }
      }
    }
  ]
}
