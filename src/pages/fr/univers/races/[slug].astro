---
import { getCollection, render } from 'astro:content';
import CodexLayout from '../../../../layouts/CodexLayout.astro';
import { useTranslations, getLocalizedPath } from '../../../../i18n/ui';

export const prerender = false;

const { slug } = Astro.params;
const slugFor = (id: string) => id.replace(/^[^/]+\//, '').replace(/\.(md|mdx)$/, '');

const matches = await getCollection('races', ({ data, id }) =>
  data.lang === 'fr' && !data.draft && slugFor(id) === slug,
);
const race = matches.at(0);
if (!race) {
  return new Response(null, { status: 404 });
}
const { Content } = await render(race);
const t = useTranslations('fr');

const raceSlug = slugFor(race.id);
const related = (
  await getCollection('characters', ({ data }) => data.lang === 'fr' && !data.draft && data.race === raceSlug)
).sort((a, b) => a.data.order - b.data.order);
---

<CodexLayout
  title={race.data.name}
  description={race.data.tagline}
  crumbs={[{ href: getLocalizedPath('fr', '/univers/races/'), label: t('races.eyebrow') }]}
  eyebrow={t('races.eyebrow')}
  ogImage={race.data.cover}
>
  {race.data.cover && (
    <div slot="meta" class="-mx-6 sm:mx-0 mb-8 overflow-hidden rounded-2xl border border-white/10">
      <img src={race.data.cover} alt={race.data.name} class="w-full h-auto object-cover" loading="eager" />
    </div>
  )}

  <div slot="meta" class="grid sm:grid-cols-2 gap-6 rounded-xl border border-white/10 bg-ink-800/40 p-6">
    <div>
      <p class="text-xs tracking-widest uppercase text-white/40">{t('races.alignment')}</p>
      <p class="mt-1 text-white">{t(`alignment.${race.data.alignment}` as any)}</p>
    </div>
    <div>
      <p class="text-xs tracking-widest uppercase text-white/40">{t('races.origin')}</p>
      <p class="mt-1 text-white">{race.data.origin}</p>
    </div>
    {race.data.traits.length > 0 && (
      <div>
        <p class="text-xs tracking-widest uppercase text-white/40">{t('races.traits')}</p>
        <ul class="mt-1 text-white/85 list-disc pl-5 space-y-1">
          {race.data.traits.map((x) => <li>{x}</li>)}
        </ul>
      </div>
    )}
    {(race.data.strengths.length > 0 || race.data.weaknesses.length > 0) && (
      <div class="grid grid-cols-2 gap-4">
        {race.data.strengths.length > 0 && (
          <div>
            <p class="text-xs tracking-widest uppercase text-angel-300/80">{t('races.strengths')}</p>
            <ul class="mt-1 text-white/85 list-disc pl-5 space-y-1">
              {race.data.strengths.map((x) => <li>{x}</li>)}
            </ul>
          </div>
        )}
        {race.data.weaknesses.length > 0 && (
          <div>
            <p class="text-xs tracking-widest uppercase text-demon-300/80">{t('races.weaknesses')}</p>
            <ul class="mt-1 text-white/85 list-disc pl-5 space-y-1">
              {race.data.weaknesses.map((x) => <li>{x}</li>)}
            </ul>
          </div>
        )}
      </div>
    )}
  </div>
  <p class="mt-6 text-xl italic text-white/80">{race.data.tagline}</p>
  <Content />

  {race.data.gallery.length > 0 && (
    <div slot="after" class="mt-16">
      <h2 class="text-xs font-display tracking-widest uppercase text-white/40">Galerie</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        {race.data.gallery.map((src) => (
          <div class="overflow-hidden rounded-lg border border-white/10 bg-ink-900">
            <img src={src} alt={race.data.name} class="w-full h-auto object-cover" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  )}

  {related.length > 0 && (
    <section slot="after" class="mt-16 pt-10 border-t border-white/10">
      <h2 class="text-2xl font-display text-white">Figures connues</h2>
      <p class="mt-2 text-white/60 text-sm">Personnages de cette race présents dans le codex.</p>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {related.map((c) => (
          <a
            href={getLocalizedPath('fr', `/univers/personnages/${slugFor(c.id)}/`)}
            class="group block rounded-xl border border-white/10 bg-ink-800/40 p-5 hover:border-gold-500/40 transition-all"
          >
            <p class="text-[10px] tracking-[0.3em] uppercase text-gold-300/80">
              {t(`characters.type_${c.data.type}` as any)}
            </p>
            <p class="mt-2 text-white group-hover:text-gold-300 transition-colors font-display">{c.data.name}</p>
            {c.data.role && <p class="mt-1 text-xs text-white/50">{c.data.role}</p>}
          </a>
        ))}
      </div>
    </section>
  )}
</CodexLayout>
