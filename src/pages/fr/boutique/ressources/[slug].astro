---
import { getCollection, render } from 'astro:content';
import CodexLayout from '../../../../layouts/CodexLayout.astro';
import { useTranslations, getLocalizedPath } from '../../../../i18n/ui';

export const prerender = false;

const { slug } = Astro.params;
const slugFor = (id: string) => id.replace(/^[^/]+\//, '').replace(/\.(md|mdx)$/, '');

const matches = await getCollection('shopPacks', ({ data, id }) =>
  data.lang === 'fr' && !data.draft && slugFor(id) === slug,
);
const pack = matches.at(0);
if (!pack) {
  return new Response(null, { status: 404 });
}
const { Content } = await render(pack);
const t = useTranslations('fr');

const currencySymbol: Record<string, string> = { eur: '€', usd: '$', gold: '◉', gems: '◆' };
const formatPrice = (price: number | undefined, currency: string) => {
  if (price === undefined) return t('shop.price_tbd');
  if (price === 0) return t('shop.price_free');
  return `${price} ${currencySymbol[currency] ?? ''}`.trim();
};
---

<CodexLayout
  title={pack.data.name}
  description={pack.data.summary}
  rootCrumb={{ href: getLocalizedPath('fr', '/boutique/'), label: t('shop.eyebrow') }}
  crumbs={[{ href: getLocalizedPath('fr', '/boutique/ressources/'), label: t('shop.packs_title') }]}
  eyebrow={t('shop.packs_eyebrow')}
  ogImage={pack.data.cover}
>
  {pack.data.cover && (
    <div slot="meta" class="-mx-6 sm:mx-0 mb-8 overflow-hidden rounded-2xl border border-white/10">
      <img src={pack.data.cover} alt={pack.data.name} class="w-full h-auto object-cover" loading="eager" />
    </div>
  )}

  <div slot="meta" class="grid sm:grid-cols-2 gap-6 rounded-xl border border-white/10 bg-ink-800/40 p-6">
    <div>
      <p class="text-xs tracking-widest uppercase text-white/40">{t('shop.type')}</p>
      <p class="mt-1 text-white">{t(`pack.${pack.data.category}` as any)}</p>
    </div>
    <div>
      <p class="text-xs tracking-widest uppercase text-white/40">{t('shop.rarity')}</p>
      <p class="mt-1 text-white">{t(`rarity.${pack.data.rarity}` as any)}</p>
    </div>
    {pack.data.contents.length > 0 && (
      <div class="sm:col-span-2">
        <p class="text-xs tracking-widest uppercase text-white/40">{t('shop.contents')}</p>
        <ul class="mt-1 text-white/85 list-disc pl-5 space-y-1">
          {pack.data.contents.map((c) => (
            <li>
              {c.quantity ? `${c.quantity} × ` : ''}{c.name}
            </li>
          ))}
        </ul>
      </div>
    )}
    <div class="sm:col-span-2 flex items-center justify-between gap-4 border-t border-white/10 pt-6">
      <span class="text-gold-300 font-display text-2xl">
        {formatPrice(pack.data.price, pack.data.currency)}
      </span>
      <button
        type="button"
        disabled
        class="text-xs font-display tracking-[0.3em] uppercase px-5 py-3 rounded border border-white/15 text-white/40 cursor-not-allowed"
        title={t('shop.soon_notice')}
      >
        {t('shop.soon')}
      </button>
    </div>
  </div>
  <p class="mt-6 text-xl italic text-white/80">{pack.data.summary}</p>
  <Content />
</CodexLayout>
