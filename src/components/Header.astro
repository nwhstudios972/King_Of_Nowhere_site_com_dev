---
import { useTranslations, getLangFromUrl, getLocalizedPath, languages, type Lang } from '../i18n/ui';
import { buildNav } from '../i18n/nav';
import LangSwitcher from './LangSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isAdmin = Astro.locals?.isAdmin ?? false;

const rest = Astro.url.pathname.replace(/^\/(fr|en)/, '') || '/';
const switchTo = (l: Lang) => `/${l}${rest === '/' ? '/' : rest}`;
const langKeys = Object.keys(languages) as Lang[];

const tabs = buildNav(lang);
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-40 transition-colors duration-300"
  data-scrolled="false"
>
  <div class="container-x flex items-center justify-between py-6">
    <a href={getLocalizedPath(lang, '/')} class="flex items-center gap-3 group shrink-0">
      <span class="text-2xl font-display tracking-[0.18em] text-white">
        KING <span class="text-gold-300">OF</span> NOWHERE
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-5 lg:gap-7" aria-label={t('nav.menu')}>
      {isAdmin && (
        <Fragment>
          {tabs.map((tab) => (
            <div class="nav-tab relative" data-nav-tab>
              <a
                href={tab.href}
                class:list={[
                  'nav-tab-link text-sm font-display tracking-widest uppercase transition-colors flex items-center gap-1.5',
                  tab.accent === 'gold'
                    ? 'text-gold-300/80 hover:text-gold-300'
                    : 'text-white/70 hover:text-white',
                ]}
                aria-haspopup={tab.categories ? 'true' : undefined}
                aria-expanded={tab.categories ? 'false' : undefined}
              >
                {t(tab.labelKey)}
                {tab.categories && (
                  <svg
                    width="10"
                    height="10"
                    viewBox="0 0 10 10"
                    aria-hidden="true"
                    class="opacity-60 transition-transform duration-200 nav-tab-chevron"
                  >
                    <path d="M2 3.5 L5 6.5 L8 3.5" stroke="currentColor" stroke-width="1.3" fill="none" stroke-linecap="round" />
                  </svg>
                )}
              </a>

              {tab.categories && (
                <div
                  class="nav-megapanel absolute left-1/2 -translate-x-1/2 top-full pt-4 hidden"
                  data-nav-panel
                >
                  <div class="rounded-2xl border border-white/10 bg-ink-900/95 backdrop-blur-md shadow-2xl shadow-black/40 p-6 min-w-[280px]">
                    <div
                      class:list={[
                        'grid gap-x-8 gap-y-6',
                        tab.categories.length > 6
                          ? 'grid-cols-3 w-[680px]'
                          : tab.categories.length > 3
                            ? 'grid-cols-2 w-[480px]'
                            : 'grid-cols-1 w-[260px]',
                      ]}
                    >
                      {tab.categories.map((cat) => (
                        <div>
                          <a
                            href={cat.href}
                            class="block text-xs font-display tracking-[0.22em] uppercase text-gold-300 hover:text-gold-200 transition-colors"
                          >
                            {t(cat.labelKey)}
                          </a>
                          {cat.children && (
                            <ul class="mt-2 space-y-1">
                              {cat.children.map((leaf) => (
                                <li>
                                  <a
                                    href={leaf.href}
                                    class="block text-sm text-white/70 hover:text-white transition-colors py-0.5"
                                  >
                                    {t(leaf.labelKey)}
                                  </a>
                                </li>
                              ))}
                            </ul>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              )}
            </div>
          ))}
          <form method="POST" action="/api/admin/logout" class="inline">
            <button
              type="submit"
              class="text-sm font-display tracking-widest uppercase text-white/40 hover:text-demon-300 transition-colors"
              aria-label="Logout"
            >
              ✕
            </button>
          </form>
        </Fragment>
      )}
      <a
        href={getLocalizedPath(lang, '/#beta')}
        class="text-sm font-display tracking-widest uppercase text-gold-300 hover:text-gold-500 transition-colors"
      >
        {t('nav.beta')}
      </a>
      <LangSwitcher />
    </nav>

    <button
      type="button"
      class="md:hidden inline-flex items-center justify-center w-11 h-11 -mr-2 text-white"
      aria-label={t('nav.menu')}
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-menu-toggle
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
        <line x1="3" y1="7" x2="21" y2="7"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="17" x2="21" y2="17"></line>
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 z-40 bg-ink-900/98 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 overflow-hidden"
    data-menu-panel
    aria-hidden="true"
  >
    <div class="container-x flex items-center justify-between py-6 relative z-10">
      <a href={getLocalizedPath(lang, '/')} class="flex items-center gap-3" data-menu-link>
        <span class="text-2xl font-display tracking-[0.18em] text-white">
          KING <span class="text-gold-300">OF</span> NOWHERE
        </span>
      </a>
      <button
        type="button"
        class="inline-flex items-center justify-center w-11 h-11 -mr-2 text-white"
        aria-label={t('nav.close')}
        data-menu-close
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
          <line x1="5" y1="5" x2="19" y2="19"></line>
          <line x1="19" y1="5" x2="5" y2="19"></line>
        </svg>
      </button>
    </div>

    <div class="relative w-full h-[calc(100vh-88px)] overflow-hidden" data-mobile-stage>
      {/* Level 1: tabs */}
      <nav
        class="mobile-screen container-x flex flex-col items-start gap-7 pt-6 pb-12 overflow-y-auto"
        data-screen-level="1"
        aria-label={t('nav.menu')}
      >
        {isAdmin && (
          <Fragment>
            {tabs.map((tab, i) => (
              tab.categories ? (
                <button
                  type="button"
                  class:list={[
                    'flex items-center justify-between w-full text-2xl font-display tracking-widest uppercase transition-colors',
                    tab.accent === 'gold'
                      ? 'text-gold-300/90 hover:text-gold-300'
                      : 'text-white/80 hover:text-white',
                  ]}
                  data-screen-open={`tab-${i}`}
                >
                  <span>{t(tab.labelKey)}</span>
                  <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true" class="opacity-60">
                    <path d="M4 2 L9 7 L4 12" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
                  </svg>
                </button>
              ) : (
                <a
                  href={tab.href}
                  class:list={[
                    'text-2xl font-display tracking-widest uppercase transition-colors',
                    tab.accent === 'gold'
                      ? 'text-gold-300/90 hover:text-gold-300'
                      : 'text-white/80 hover:text-white',
                  ]}
                  data-menu-link
                >
                  {t(tab.labelKey)}
                </a>
              )
            ))}
          </Fragment>
        )}
        <a
          href={getLocalizedPath(lang, '/#beta')}
          class="text-2xl font-display tracking-widest uppercase text-gold-300 hover:text-gold-500 transition-colors"
          data-menu-link
        >
          {t('nav.beta')}
        </a>

        <div class="mt-8 pt-8 border-t border-white/10 w-full flex items-center gap-4">
          {langKeys.map((l) => (
            <a
              href={switchTo(l)}
              class:list={[
                'text-base font-display tracking-widest px-3 py-1 rounded transition-colors',
                lang === l ? 'text-gold-300' : 'text-white/50 hover:text-white',
              ]}
              aria-current={lang === l ? 'page' : undefined}
            >
              {l.toUpperCase()}
            </a>
          ))}
          {isAdmin && (
            <form method="POST" action="/api/admin/logout" class="ml-auto inline">
              <button
                type="submit"
                class="text-sm font-display tracking-widest uppercase text-white/40 hover:text-demon-300 transition-colors"
              >
                ✕
              </button>
            </form>
          )}
        </div>
      </nav>

      {/* Level 2: categories per tab */}
      {isAdmin && tabs.map((tab, i) =>
        tab.categories ? (
          <nav
            class="mobile-screen container-x flex flex-col items-start gap-5 pt-2 pb-12 overflow-y-auto"
            data-screen-id={`tab-${i}`}
            aria-label={t(tab.labelKey)}
            aria-hidden="true"
          >
            <button
              type="button"
              class="flex items-center gap-2 text-xs font-display tracking-widest uppercase text-white/50 hover:text-white transition-colors"
              data-screen-back
            >
              <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
                <path d="M9 2 L4 7 L9 12" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
              </svg>
              <span>{t(tab.labelKey)}</span>
            </button>
            <a
              href={tab.href}
              class="text-xl font-display tracking-widest uppercase text-gold-300 hover:text-gold-500 transition-colors pb-2"
              data-menu-link
            >
              {t(tab.labelKey)} →
            </a>
            {tab.categories.map((cat, j) =>
              cat.children ? (
                <button
                  type="button"
                  class="flex items-center justify-between w-full text-lg font-display tracking-wide text-white/80 hover:text-white transition-colors"
                  data-screen-open={`tab-${i}-cat-${j}`}
                >
                  <span>{t(cat.labelKey)}</span>
                  <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true" class="opacity-60">
                    <path d="M4 2 L9 7 L4 12" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
                  </svg>
                </button>
              ) : (
                <a
                  href={cat.href}
                  class="text-lg font-display tracking-wide text-white/80 hover:text-white transition-colors"
                  data-menu-link
                >
                  {t(cat.labelKey)}
                </a>
              )
            )}
          </nav>
        ) : null,
      )}

      {/* Level 3: leaves per category */}
      {isAdmin && tabs.map((tab, i) =>
        tab.categories?.map((cat, j) =>
          cat.children ? (
            <nav
              class="mobile-screen container-x flex flex-col items-start gap-4 pt-2 pb-12 overflow-y-auto"
              data-screen-id={`tab-${i}-cat-${j}`}
              aria-label={t(cat.labelKey)}
              aria-hidden="true"
            >
              <button
                type="button"
                class="flex items-center gap-2 text-xs font-display tracking-widest uppercase text-white/50 hover:text-white transition-colors"
                data-screen-back
              >
                <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
                  <path d="M9 2 L4 7 L9 12" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
                </svg>
                <span>{t(tab.labelKey)}</span>
              </button>
              <a
                href={cat.href}
                class="text-xl font-display tracking-widest uppercase text-gold-300 hover:text-gold-500 transition-colors pb-2"
                data-menu-link
              >
                {t(cat.labelKey)} →
              </a>
              {cat.children.map((leaf) => (
                <a
                  href={leaf.href}
                  class="text-base text-white/75 hover:text-white transition-colors"
                  data-menu-link
                >
                  {t(leaf.labelKey)}
                </a>
              ))}
            </nav>
          ) : null,
        ),
      )}
    </div>
  </div>
</header>

<style>
  /* Scroll-aware background */
  #site-header[data-scrolled='true'] {
    background-color: rgb(10 8 14 / 0.85);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgb(255 255 255 / 0.06);
  }

  /* Desktop: open mega-panel on hover/focus */
  .nav-tab:hover [data-nav-panel],
  .nav-tab:focus-within [data-nav-panel] {
    display: block;
  }
  .nav-tab:hover .nav-tab-chevron,
  .nav-tab:focus-within .nav-tab-chevron {
    transform: rotate(180deg);
  }

  /* Mobile sliding screens */
  .mobile-screen {
    position: absolute;
    inset: 0;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    visibility: hidden;
  }
  .mobile-screen[data-active='true'] {
    transform: translateX(0);
    visibility: visible;
  }
  .mobile-screen[data-prev='true'] {
    transform: translateX(-30%);
    visibility: visible;
    opacity: 0.4;
    pointer-events: none;
  }
  .mobile-screen[data-screen-level='1'] {
    transform: translateX(-100%);
  }
  .mobile-screen[data-screen-level='1'][data-active='true'] {
    transform: translateX(0);
  }
</style>

<script>
  function setupHeader() {
    const header = document.getElementById('site-header');
    if (!header) return;

    /* --- scroll-aware bg --- */
    const onScroll = () => {
      header.setAttribute('data-scrolled', window.scrollY > 20 ? 'true' : 'false');
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    /* --- mobile menu --- */
    const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    const panel = document.querySelector<HTMLElement>('[data-menu-panel]');
    const close = document.querySelector<HTMLButtonElement>('[data-menu-close]');
    const stage = document.querySelector<HTMLElement>('[data-mobile-stage]');
    const screens = stage
      ? Array.from(stage.querySelectorAll<HTMLElement>('.mobile-screen'))
      : [];
    const screenStack: string[] = ['root'];

    const setActiveScreen = (id: string) => {
      screens.forEach((s) => {
        const sid =
          s.getAttribute('data-screen-level') === '1'
            ? 'root'
            : s.getAttribute('data-screen-id') || '';
        s.setAttribute('data-active', sid === id ? 'true' : 'false');
        s.setAttribute('data-prev', 'false');
        s.setAttribute('aria-hidden', sid === id ? 'false' : 'true');
      });
    };

    const goTo = (id: string) => {
      screenStack.push(id);
      setActiveScreen(id);
    };
    const goBack = () => {
      if (screenStack.length > 1) {
        screenStack.pop();
        setActiveScreen(screenStack[screenStack.length - 1]);
      }
    };
    const resetScreens = () => {
      screenStack.length = 0;
      screenStack.push('root');
      setActiveScreen('root');
    };

    if (toggle && panel && close) {
      const open = () => {
        panel.classList.remove('opacity-0', 'pointer-events-none');
        panel.classList.add('opacity-100');
        panel.setAttribute('aria-hidden', 'false');
        toggle.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        resetScreens();
      };
      const closeMenu = () => {
        panel.classList.add('opacity-0', 'pointer-events-none');
        panel.classList.remove('opacity-100');
        panel.setAttribute('aria-hidden', 'true');
        toggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      };

      toggle.addEventListener('click', open);
      close.addEventListener('click', closeMenu);
      document
        .querySelectorAll<HTMLAnchorElement>('[data-menu-link]')
        .forEach((link) => link.addEventListener('click', closeMenu));

      document.querySelectorAll<HTMLButtonElement>('[data-screen-open]').forEach((btn) => {
        const target = btn.getAttribute('data-screen-open');
        if (target) btn.addEventListener('click', () => goTo(target));
      });
      document.querySelectorAll<HTMLButtonElement>('[data-screen-back]').forEach((btn) => {
        btn.addEventListener('click', goBack);
      });

      // Initialize active screen
      setActiveScreen('root');

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
          closeMenu();
        }
      });

      const mql = window.matchMedia('(min-width: 768px)');
      mql.addEventListener('change', (e) => {
        if (e.matches) closeMenu();
      });
    }
  }

  setupHeader();
  document.addEventListener('astro:page-load', setupHeader);
</script>
