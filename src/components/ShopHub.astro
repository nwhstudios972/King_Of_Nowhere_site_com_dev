---
import { useTranslations, getLangFromUrl, getLocalizedPath } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const shopBase = lang === 'fr' ? '/boutique' : '/shop';
const petsSlug = lang === 'fr' ? 'mascottes' : 'pets';
const mountsSlug = lang === 'fr' ? 'montures' : 'mounts';
const packsSlug = lang === 'fr' ? 'ressources' : 'resources';
const cosmeticsSlug = lang === 'fr' ? 'cosmetiques' : 'cosmetics';

const cards = [
  {
    title: t('shop.pets_title'),
    lead: t('shop.pets_lead'),
    href: getLocalizedPath(lang, `${shopBase}/${petsSlug}/`),
    accent: 'angel',
    icon: '✦',
  },
  {
    title: t('shop.mounts_title'),
    lead: t('shop.mounts_lead'),
    href: getLocalizedPath(lang, `${shopBase}/${mountsSlug}/`),
    accent: 'gold',
    icon: '⛧',
  },
  {
    title: t('shop.cosmetics_title'),
    lead: t('shop.cosmetics_lead'),
    href: getLocalizedPath(lang, `${shopBase}/${cosmeticsSlug}/`),
    accent: 'angel',
    icon: '✧',
  },
  {
    title: t('shop.packs_title'),
    lead: t('shop.packs_lead'),
    href: getLocalizedPath(lang, `${shopBase}/${packsSlug}/`),
    accent: 'demon',
    icon: '⚱',
  },
];

const accentClasses = {
  gold: 'border-gold-500/20 hover:border-gold-300/60 text-gold-300',
  angel: 'border-angel-500/20 hover:border-angel-300/60 text-angel-300',
  demon: 'border-demon-500/20 hover:border-demon-300/60 text-demon-300',
};
---

<section class="pt-32 pb-24">
  <div class="container-x">
    <p class="eyebrow reveal">{t('shop.eyebrow')}</p>
    <h1 class="reveal mt-4 text-4xl sm:text-6xl text-white max-w-3xl leading-tight">
      {t('shop.title')}
    </h1>
    <p class="reveal mt-6 max-w-2xl text-lg text-white/70 leading-relaxed">
      {t('shop.lead')}
    </p>

    <div class="reveal mt-10 rounded-xl border border-gold-300/30 bg-gold-500/5 px-6 py-4 text-sm text-gold-200/90">
      <span class="font-display tracking-widest uppercase text-gold-300 mr-2">{t('shop.soon')}</span>
      {t('shop.soon_notice')}
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        cards.map((c, i) => (
          <a
            href={c.href}
            class:list={[
              'reveal group rounded-2xl border p-8 bg-ink-800/50 hover:-translate-y-1 transition-all duration-300',
              accentClasses[c.accent as keyof typeof accentClasses],
            ]}
            style={`animation-delay: ${0.1 * i}s`}
          >
            <div class="text-3xl mb-5">{c.icon}</div>
            <h2 class="text-2xl text-white font-display">{c.title}</h2>
            <p class="mt-3 text-white/65 leading-relaxed text-sm">{c.lead}</p>
            <span class="mt-6 inline-block text-xs font-display tracking-widest uppercase opacity-80">
              →
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
