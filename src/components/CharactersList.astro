---
import { getCollection } from 'astro:content';
import { useTranslations, getLangFromUrl, getLocalizedPath, type Lang } from '../i18n/ui';
import { CHARACTER_TYPES } from '../content/config';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const all = await getCollection('characters', ({ data }) => data.lang === lang && !data.draft);
const characters = all.sort((a, b) => {
  const orderDiff = a.data.order - b.data.order;
  return orderDiff !== 0 ? orderDiff : a.data.name.localeCompare(b.data.name);
});

const slugFor = (id: string) => id.replace(/^[^/]+\//, '').replace(/\.(md|mdx)$/, '');

const filters = [
  { value: 'all', label: t('characters.filter_all') },
  { value: 'entite', label: t('characters.filter_entite') },
  { value: 'elite', label: t('characters.filter_elite') },
  { value: 'marchand', label: t('characters.filter_marchand') },
  { value: 'aubergiste', label: t('characters.filter_aubergiste') },
  { value: 'gardien', label: t('characters.filter_gardien') },
  { value: 'basique', label: t('characters.filter_basique') },
];

const typeStyle = (type: string) =>
  type === 'entite'
    ? 'border-white/40 text-white bg-white/10'
    : type === 'elite'
      ? 'border-gold-500/40 text-gold-300 bg-gold-500/5'
      : type === 'gardien'
        ? 'border-angel-500/30 text-angel-300 bg-angel-500/5'
        : type === 'marchand'
          ? 'border-emerald-500/30 text-emerald-300 bg-emerald-500/5'
          : type === 'aubergiste'
            ? 'border-amber-500/30 text-amber-300 bg-amber-500/5'
            : 'border-white/15 text-white/70 bg-white/5';

const factionStyle = (f: string) =>
  f === 'angel'
    ? 'text-angel-300'
    : f === 'demon'
      ? 'text-demon-300'
      : 'text-white/50';
---

<section class="pt-32 pb-24">
  <div class="container-x">
    <a
      href={getLocalizedPath(lang, '/univers/')}
      class="text-sm font-display tracking-widest uppercase text-gold-300 hover:text-gold-500 transition-colors"
    >
      ← {t('universe.eyebrow')}
    </a>
    <p class="eyebrow mt-8">{t('characters.eyebrow')}</p>
    <h1 class="mt-4 text-4xl sm:text-5xl text-white">{t('characters.title')}</h1>
    <p class="mt-4 max-w-2xl text-white/70">{t('characters.lead')}</p>

    <div id="char-filters" class="mt-10 flex flex-wrap gap-2">
      {
        filters.map((f) => (
          <button
            type="button"
            class="filter-pill text-xs font-display tracking-widest uppercase px-4 py-2 rounded-full border border-white/10 text-white/60 hover:border-gold-300/60 hover:text-gold-300 transition-all data-[active=true]:border-gold-300 data-[active=true]:text-gold-300 data-[active=true]:bg-gold-500/10"
            data-filter={f.value}
            data-active={f.value === 'all' ? 'true' : 'false'}
          >
            {f.label}
          </button>
        ))
      }
    </div>

    {
      characters.length === 0 ? (
        <p class="mt-16 text-white/40 italic">{t('characters.empty')}</p>
      ) : (
        <div id="char-grid" class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {characters.map((c) => (
            <a
              href={getLocalizedPath(lang, `/univers/personnages/${slugFor(c.id)}/`)}
              class="character-card group rounded-xl border border-white/10 bg-ink-800/40 p-6 hover:border-gold-500/40 transition-all hover:-translate-y-1 duration-300 block"
              data-type={c.data.type}
            >
              <div class="flex items-center justify-between gap-3">
                <span
                  class:list={[
                    'inline-block text-[10px] tracking-[0.3em] uppercase px-2 py-1 rounded border font-display',
                    typeStyle(c.data.type),
                  ]}
                >
                  {t(`characters.type_${c.data.type}` as any)}
                </span>
                {c.data.faction !== 'neutral' && (
                  <span class:list={['text-xs font-display tracking-widest uppercase', factionStyle(c.data.faction)]}>
                    {t(`faction.${c.data.faction}` as any)}
                  </span>
                )}
              </div>
              <h2 class="mt-4 text-xl text-white group-hover:text-gold-300 transition-colors font-display">
                {c.data.name}
              </h2>
              {c.data.role && <p class="mt-1 text-sm text-white/50">{c.data.role}</p>}
              <p class="mt-3 text-white/65 text-sm leading-relaxed line-clamp-3">{c.data.summary}</p>
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('#char-filters .filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('.character-card');

  filters.forEach((pill) => {
    pill.addEventListener('click', () => {
      const value = pill.dataset.filter || 'all';
      filters.forEach((p) => p.setAttribute('data-active', p === pill ? 'true' : 'false'));
      cards.forEach((card) => {
        const match = value === 'all' || card.dataset.type === value;
        card.style.display = match ? '' : 'none';
      });
    });
  });
</script>
