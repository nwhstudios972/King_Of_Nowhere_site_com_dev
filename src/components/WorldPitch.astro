---
import { useTranslations, getLangFromUrl, getLocalizedPath } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const points = [
  { title: t('world.point1_title'), text: t('world.point1_text'), icon: '⛰', href: getLocalizedPath(lang, '/univers/construire/') },
  { title: t('world.point2_title'), text: t('world.point2_text'), icon: '⚔', href: getLocalizedPath(lang, '/univers/camps/') },
  { title: t('world.point3_title'), text: t('world.point3_text'), icon: '𓂀', href: getLocalizedPath(lang, '/univers/environnement/') },
];
---

<section id="world" class="section">
  <div class="container-x">
    <p class="eyebrow reveal">{t('world.eyebrow')}</p>
    <h2 class="reveal mt-4 text-4xl sm:text-5xl text-white max-w-3xl">
      {t('world.title')}
    </h2>
    <p class="reveal mt-6 max-w-2xl text-lg text-white/70 leading-relaxed">
      {t('world.lead')}
    </p>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {
        points.map((p, i) => (
          <a
            href={p.href}
            class="reveal group block rounded-xl border border-white/10 bg-ink-800/50 p-7 hover:border-gold-500/30 hover:-translate-y-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold-300/70 transition-all duration-300"
            style={`animation-delay: ${0.1 * i}s`}
          >
            <div class="text-3xl text-gold-300 mb-4">{p.icon}</div>
            <h3 class="text-xl text-white group-hover:text-gold-300 transition-colors">{p.title}</h3>
            <p class="mt-3 text-white/60 leading-relaxed text-sm">{p.text}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
