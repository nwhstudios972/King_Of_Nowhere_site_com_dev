---
import { useTranslations, getLangFromUrl } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const points = [
  { title: t('world.point1_title'), text: t('world.point1_text'), icon: '⛰' },
  { title: t('world.point2_title'), text: t('world.point2_text'), icon: '⚔' },
  { title: t('world.point3_title'), text: t('world.point3_text'), icon: '𓂀' },
];
---

<section id="world" class="section">
  <div class="container-x">
    <p class="eyebrow reveal">{t('world.eyebrow')}</p>
    <h2 class="reveal mt-4 text-4xl sm:text-5xl text-white max-w-3xl">
      {t('world.title')}
    </h2>
    <p class="reveal mt-6 max-w-2xl text-lg text-white/70 leading-relaxed">
      {t('world.lead')}
    </p>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {
        points.map((p, i) => (
          <div
            class="reveal rounded-xl border border-white/10 bg-ink-800/50 p-7 hover:border-gold-500/30 transition-colors"
            style={`animation-delay: ${0.1 * i}s`}
          >
            <div class="text-3xl text-gold-300 mb-4">{p.icon}</div>
            <h3 class="text-xl text-white">{p.title}</h3>
            <p class="mt-3 text-white/60 leading-relaxed text-sm">{p.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
