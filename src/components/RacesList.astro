---
import { getCollection } from 'astro:content';
import { useTranslations, getLangFromUrl, getLocalizedPath, type Lang } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const all = await getCollection('races', ({ data }) => data.lang === lang && !data.draft);
const races = all.sort((a, b) => a.data.order - b.data.order);

const slugFor = (id: string) => id.replace(/^[^/]+\//, '').replace(/\.(md|mdx)$/, '');

const alignmentClass = (a: string) =>
  a === 'good'
    ? 'border-angel-500/30 text-angel-300'
    : a === 'evil'
      ? 'border-demon-500/30 text-demon-300'
      : 'border-white/15 text-white/60';

const filters = [
  { value: 'all', label: lang === 'fr' ? 'Toutes' : 'All' },
  { value: 'good', label: t('alignment.good') },
  { value: 'neutral', label: t('alignment.neutral') },
  { value: 'evil', label: t('alignment.evil') },
];
---

<section class="pt-32 pb-24">
  <div class="container-x">
    <a
      href={getLocalizedPath(lang, '/univers/')}
      class="text-sm font-display tracking-widest uppercase text-gold-300 hover:text-gold-500 transition-colors"
    >
      ← {t('universe.eyebrow')}
    </a>
    <p class="eyebrow mt-8">{t('races.eyebrow')}</p>
    <h1 class="mt-4 text-4xl sm:text-5xl text-white">{t('races.title')}</h1>
    <p class="mt-4 max-w-2xl text-white/70">{t('races.lead')}</p>

    <div id="race-filters" class="mt-10 flex flex-wrap gap-2">
      {filters.map((f) => (
        <button
          type="button"
          class="filter-pill text-xs font-display tracking-widest uppercase px-4 py-2 rounded-full border border-white/10 text-white/60 hover:border-gold-300/60 hover:text-gold-300 transition-all data-[active=true]:border-gold-300 data-[active=true]:text-gold-300 data-[active=true]:bg-gold-500/10"
          data-filter={f.value}
          data-active={f.value === 'all' ? 'true' : 'false'}
        >
          {f.label}
        </button>
      ))}
    </div>

    {
      races.length === 0 ? (
        <p class="mt-16 text-white/40 italic">{t('races.empty')}</p>
      ) : (
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {races.map((r) => (
            <a
              href={getLocalizedPath(lang, `/univers/races/${slugFor(r.id)}/`)}
              class="race-card group rounded-xl border border-white/10 bg-ink-800/40 overflow-hidden hover:border-gold-500/40 transition-all hover:-translate-y-1 duration-300 block"
              data-alignment={r.data.alignment}
            >
              {r.data.cover ? (
                <div class="aspect-[4/3] overflow-hidden bg-ink-900">
                  <img
                    src={r.data.cover}
                    alt={r.data.name}
                    loading="lazy"
                    class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
              ) : (
                <div class="aspect-[4/3] bg-gradient-to-br from-ink-700 to-ink-900 border-b border-white/5 flex items-center justify-center">
                  <span class="text-5xl text-white/10 font-display">𓂀</span>
                </div>
              )}
              <div class="p-6">
                <span
                  class:list={[
                    'inline-block text-[10px] tracking-[0.3em] uppercase px-2 py-1 rounded border font-display',
                    alignmentClass(r.data.alignment),
                  ]}
                >
                  {t(`alignment.${r.data.alignment}` as any)}
                </span>
                <h2 class="mt-4 text-2xl text-white group-hover:text-gold-300 transition-colors font-display">
                  {r.data.name}
                </h2>
                <p class="mt-3 text-white/65 italic text-sm">{r.data.tagline}</p>
              </div>
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>

<script>
  function setupRaceFilters() {
    const pills = document.querySelectorAll<HTMLButtonElement>('#race-filters .filter-pill');
    const cards = document.querySelectorAll<HTMLElement>('.race-card');
    if (!pills.length) return;

    const apply = (value: string) => {
      pills.forEach((p) =>
        p.setAttribute('data-active', p.dataset.filter === value ? 'true' : 'false'),
      );
      cards.forEach((card) => {
        const match = value === 'all' || card.dataset.alignment === value;
        (card as HTMLElement).style.display = match ? '' : 'none';
      });
    };

    pills.forEach((p) => p.addEventListener('click', () => apply(p.dataset.filter || 'all')));

    const hash = window.location.hash.replace(/^#/, '');
    if (hash) {
      const match = Array.from(pills).find((p) => p.dataset.filter === hash);
      if (match) apply(hash);
    }
  }
  setupRaceFilters();
  document.addEventListener('astro:page-load', setupRaceFilters);
</script>
