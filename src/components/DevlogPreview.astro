---
import { getCollection } from 'astro:content';
import { useTranslations, getLangFromUrl, getLocalizedPath, type Lang } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const all = await getCollection('devlog', ({ data }) => data.lang === lang && !data.draft);
const posts = all
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const dateFmt = new Intl.DateTimeFormat(lang === 'fr' ? 'fr-FR' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const slugFor = (id: string) => id.replace(/^[^/]+\//, '').replace(/\.(md|mdx)$/, '');
---

<section class="section bg-ink-800/30">
  <div class="container-x">
    <div class="flex flex-wrap items-end justify-between gap-6 mb-12">
      <div>
        <p class="eyebrow reveal">{t('devlog.eyebrow')}</p>
        <h2 class="reveal mt-4 text-4xl sm:text-5xl text-white">
          {t('devlog.title')}
        </h2>
        <p class="reveal mt-4 max-w-xl text-white/60">{t('devlog.lead')}</p>
      </div>
      <a
        href={getLocalizedPath(lang, '/devlog/')}
        class="reveal text-sm font-display tracking-widest uppercase text-gold-300 hover:text-gold-500 transition-colors"
      >
        {t('devlog.see_all')} →
      </a>
    </div>

    {
      posts.length === 0 ? (
        <p class="text-white/40 italic">{t('devlog.empty')}</p>
      ) : (
        <div class="grid gap-6 md:grid-cols-3">
          {posts.map((post, i) => (
            <a
              href={getLocalizedPath(lang, `/devlog/${slugFor(post.id)}/`)}
              class="reveal group rounded-xl border border-white/10 bg-ink-700/40 p-6 hover:border-gold-500/40 transition-all hover:-translate-y-1 duration-300"
              style={`animation-delay: ${0.1 * i}s`}
            >
              <p class="text-xs text-white/40 tracking-widest uppercase">
                {dateFmt.format(post.data.date)}
              </p>
              <h3 class="mt-3 text-xl text-white group-hover:text-gold-300 transition-colors">
                {post.data.title}
              </h3>
              <p class="mt-3 text-sm text-white/60 leading-relaxed line-clamp-3">
                {post.data.excerpt}
              </p>
              <span class="mt-5 inline-block text-xs font-display tracking-widest uppercase text-gold-300/80">
                {t('devlog.read_more')} →
              </span>
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>
