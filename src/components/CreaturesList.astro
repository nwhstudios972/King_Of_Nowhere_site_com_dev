---
import { getCollection } from 'astro:content';
import { useTranslations, getLangFromUrl, getLocalizedPath } from '../i18n/ui';
import { CREATURE_TYPES } from '../content/config';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const all = await getCollection('creatures', ({ data }) => data.lang === lang && !data.draft);
const creatures = all.sort((a, b) => a.data.order - b.data.order);

const slugFor = (id: string) => id.replace(/^[^/]+\//, '').replace(/\.(md|mdx)$/, '');

const threatClass = (level: string) => {
  switch (level) {
    case 'minor':
      return 'border-white/15 text-white/60';
    case 'standard':
      return 'border-gold-500/30 text-gold-300';
    case 'elite':
      return 'border-demon-500/30 text-demon-300';
    case 'boss':
      return 'border-demon-500/60 text-demon-200 bg-demon-900/20';
    case 'legendary':
      return 'border-gold-300/60 text-gold-200 bg-gold-900/10';
    default:
      return 'border-white/15 text-white/60';
  }
};

const filters = [
  { value: 'all', label: lang === 'fr' ? 'Toutes' : 'All' },
  ...CREATURE_TYPES.map((c) => ({ value: c, label: t(`creature.${c}` as any) })),
];
---

<section class="pt-32 pb-24">
  <div class="container-x">
    <a
      href={getLocalizedPath(lang, '/univers/')}
      class="text-sm font-display tracking-widest uppercase text-gold-300 hover:text-gold-500 transition-colors"
    >
      ← {t('universe.eyebrow')}
    </a>
    <p class="eyebrow mt-8">{t('creatures.eyebrow')}</p>
    <h1 class="mt-4 text-4xl sm:text-5xl text-white">{t('creatures.title')}</h1>
    <p class="mt-4 max-w-2xl text-white/70">{t('creatures.lead')}</p>

    <div id="creature-filters" class="mt-10 flex flex-wrap gap-2">
      {filters.map((f) => (
        <button
          type="button"
          class="filter-pill text-xs font-display tracking-widest uppercase px-4 py-2 rounded-full border border-white/10 text-white/60 hover:border-gold-300/60 hover:text-gold-300 transition-all data-[active=true]:border-gold-300 data-[active=true]:text-gold-300 data-[active=true]:bg-gold-500/10"
          data-filter={f.value}
          data-active={f.value === 'all' ? 'true' : 'false'}
        >
          {f.label}
        </button>
      ))}
    </div>

    {
      creatures.length === 0 ? (
        <p class="mt-16 text-white/40 italic">{t('creatures.empty')}</p>
      ) : (
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {creatures.map((c) => (
            <a
              href={getLocalizedPath(lang, `/univers/creatures/${slugFor(c.id)}/`)}
              class="creature-card group rounded-xl border border-white/10 bg-ink-800/40 overflow-hidden hover:border-gold-500/40 transition-all hover:-translate-y-1 duration-300 block"
              data-type={c.data.type}
            >
              {c.data.cover ? (
                <div class="aspect-[4/3] overflow-hidden bg-ink-900">
                  <img
                    src={c.data.cover}
                    alt={c.data.name}
                    loading="lazy"
                    class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
              ) : (
                <div class="aspect-[4/3] bg-gradient-to-br from-ink-700 to-ink-900 border-b border-white/5 flex items-center justify-center">
                  <span class="text-5xl text-white/10 font-display">☠</span>
                </div>
              )}
              <div class="p-6">
                <div class="flex flex-wrap gap-2">
                  <span class="inline-block text-[10px] tracking-[0.3em] uppercase px-2 py-1 rounded border border-white/15 text-white/60 font-display">
                    {t(`creature.${c.data.type}` as any)}
                  </span>
                  <span
                    class:list={[
                      'inline-block text-[10px] tracking-[0.3em] uppercase px-2 py-1 rounded border font-display',
                      threatClass(c.data.threatLevel),
                    ]}
                  >
                    {t(`threat.${c.data.threatLevel}` as any)}
                  </span>
                </div>
                <h2 class="mt-4 text-2xl text-white group-hover:text-gold-300 transition-colors font-display">
                  {c.data.name}
                </h2>
                {c.data.tagline && (
                  <p class="mt-3 text-white/65 italic text-sm">{c.data.tagline}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>

<script>
  function setupCreatureFilters() {
    const pills = document.querySelectorAll<HTMLButtonElement>('#creature-filters .filter-pill');
    const cards = document.querySelectorAll<HTMLElement>('.creature-card');
    if (!pills.length) return;

    const apply = (value: string) => {
      pills.forEach((p) =>
        p.setAttribute('data-active', p.dataset.filter === value ? 'true' : 'false'),
      );
      cards.forEach((card) => {
        const match = value === 'all' || card.dataset.type === value;
        (card as HTMLElement).style.display = match ? '' : 'none';
      });
    };

    pills.forEach((p) => p.addEventListener('click', () => apply(p.dataset.filter || 'all')));

    const hash = window.location.hash.replace(/^#/, '');
    if (hash) {
      const match = Array.from(pills).find((p) => p.dataset.filter === hash);
      if (match) apply(hash);
    }
  }
  setupCreatureFilters();
  document.addEventListener('astro:page-load', setupCreatureFilters);
</script>
