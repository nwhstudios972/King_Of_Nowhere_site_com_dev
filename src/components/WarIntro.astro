---
import { useTranslations, getLangFromUrl } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section relative overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div
      class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-px"
      style="background: linear-gradient(90deg, transparent, rgba(243,212,136,0.4), transparent);"
    ></div>
  </div>
  <div class="container-x text-center">
    <p class="eyebrow reveal">{t('war.eyebrow')}</p>
    <h2
      class="reveal mt-6 text-4xl sm:text-6xl text-white max-w-4xl mx-auto leading-tight"
    >
      {t('war.title')}
    </h2>
    <p
      class="reveal mt-8 max-w-2xl mx-auto text-lg text-white/70 leading-relaxed"
    >
      {t('war.lead')}
    </p>
  </div>
</section>
