---
import { useTranslations, getLangFromUrl, getLocalizedPath } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cards = [
  {
    title: t('universe.characters_title'),
    lead: t('universe.characters_lead'),
    href: getLocalizedPath(lang, '/univers/personnages/'),
    accent: 'gold',
    icon: '⚔',
  },
  {
    title: t('universe.races_title'),
    lead: t('universe.races_lead'),
    href: getLocalizedPath(lang, '/univers/races/'),
    accent: 'angel',
    icon: '𓂀',
  },
  {
    title: t('universe.resources_title'),
    lead: t('universe.resources_lead'),
    href: getLocalizedPath(lang, '/univers/ressources/'),
    accent: 'demon',
    icon: '✦',
  },
  {
    title: t('universe.weapons_title'),
    lead: t('universe.weapons_lead'),
    href: getLocalizedPath(lang, '/univers/armes/'),
    accent: 'gold',
    icon: '⚒',
  },
  {
    title: t('universe.skills_title'),
    lead: t('universe.skills_lead'),
    href: getLocalizedPath(lang, '/univers/competences/'),
    accent: 'angel',
    icon: '✺',
  },
  {
    title: t('universe.biomes_title'),
    lead: t('universe.biomes_lead'),
    href: getLocalizedPath(lang, '/univers/environnement/'),
    accent: 'demon',
    icon: '⛰',
  },
  {
    title: t('universe.creatures_title'),
    lead: t('universe.creatures_lead'),
    href: getLocalizedPath(lang, '/univers/creatures/'),
    accent: 'demon',
    icon: '☠',
  },
  {
    title: t('universe.camps_title'),
    lead: t('universe.camps_lead'),
    href: getLocalizedPath(lang, '/univers/camps/'),
    accent: 'gold',
    icon: '⚖',
  },
  {
    title: t('universe.build_title'),
    lead: t('universe.build_lead'),
    href: getLocalizedPath(lang, '/univers/construire/'),
    accent: 'angel',
    icon: '⊞',
  },
  {
    title: t('universe.rules_title'),
    lead: t('universe.rules_lead'),
    href: getLocalizedPath(lang, '/univers/regles/'),
    accent: 'gold',
    icon: '⚖',
  },
];

const accentClasses = {
  gold: 'border-gold-500/20 hover:border-gold-300/60 text-gold-300',
  angel: 'border-angel-500/20 hover:border-angel-300/60 text-angel-300',
  demon: 'border-demon-500/20 hover:border-demon-300/60 text-demon-300',
};
---

<section class="pt-32 pb-24">
  <div class="container-x">
    <p class="eyebrow reveal">{t('universe.eyebrow')}</p>
    <h1 class="reveal mt-4 text-4xl sm:text-6xl text-white max-w-3xl leading-tight">
      {t('universe.title')}
    </h1>
    <p class="reveal mt-6 max-w-2xl text-lg text-white/70 leading-relaxed">
      {t('universe.lead')}
    </p>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {
        cards.map((c, i) => (
          <a
            href={c.href}
            class:list={[
              'reveal group rounded-2xl border p-8 bg-ink-800/50 hover:-translate-y-1 transition-all duration-300',
              accentClasses[c.accent as keyof typeof accentClasses],
            ]}
            style={`animation-delay: ${0.1 * i}s`}
          >
            <div class="text-3xl mb-5">{c.icon}</div>
            <h2 class="text-2xl text-white font-display">{c.title}</h2>
            <p class="mt-3 text-white/65 leading-relaxed text-sm">{c.lead}</p>
            <span class="mt-6 inline-block text-xs font-display tracking-widest uppercase opacity-80">
              →
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
