---
import { useTranslations, getLangFromUrl } from '../i18n/ui';
import BetaSignup from './BetaSignup.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-24 pb-16">
  <!-- Starfield base layer -->
  <div class="absolute inset-0 -z-30 starfield opacity-70"></div>

  <!-- Deep gradient backdrop -->
  <div
    class="absolute inset-0 -z-20"
    style="background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(11,13,20,0) 0%, #06070b 75%);"
  ></div>

  <!-- Angel halo, top-left -->
  <div
    class="absolute -top-32 -left-32 w-[55vw] h-[55vw] max-w-[700px] max-h-[700px] rounded-full blur-3xl animate-glow-pulse -z-10"
    style="background: radial-gradient(circle, rgba(91,141,239,0.35) 0%, rgba(91,141,239,0) 65%);"
  ></div>

  <!-- Demon halo, bottom-right -->
  <div
    class="absolute -bottom-32 -right-32 w-[55vw] h-[55vw] max-w-[700px] max-h-[700px] rounded-full blur-3xl animate-glow-pulse -z-10"
    style="background: radial-gradient(circle, rgba(216,58,26,0.32) 0%, rgba(216,58,26,0) 65%); animation-delay: 2s;"
  ></div>

  <!-- Gold soft glow behind title -->
  <div
    class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[70vw] h-[40vw] max-w-[900px] rounded-full blur-3xl opacity-40 -z-10"
    style="background: radial-gradient(ellipse, rgba(200,154,58,0.18) 0%, transparent 70%);"
  ></div>

  <!-- Vignette -->
  <div
    class="absolute inset-0 -z-10 pointer-events-none"
    style="background: radial-gradient(ellipse at center, transparent 40%, rgba(6,7,11,0.7) 100%);"
  ></div>

  <div class="container-x relative">
    <div class="max-w-4xl mx-auto text-center">
      <p class="eyebrow reveal">{t('comingSoon.eyebrow')}</p>

      <h1
        class="reveal mt-6 font-display text-5xl sm:text-7xl lg:text-8xl tracking-[0.08em] leading-[1.05] uppercase"
        style="background: linear-gradient(180deg, #f3d488 0%, #c89a3a 50%, #8a6a1f 100%); -webkit-background-clip: text; background-clip: text; color: transparent; text-shadow: 0 0 60px rgba(200,154,58,0.25);"
      >
        King <span class="block sm:inline">Of Nowhere</span>
      </h1>

      <p class="reveal mt-8 text-xl sm:text-2xl text-white/90 font-display tracking-wide italic">
        {t('comingSoon.tagline')}
      </p>

      <p class="reveal mt-8 text-base sm:text-lg text-white/70 leading-relaxed max-w-2xl mx-auto">
        {t('comingSoon.lead')}
      </p>

      <div class="reveal mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#beta" class="btn-primary">
          {t('comingSoon.beta_intro')}
        </a>
      </div>

      <p class="reveal mt-16 text-xs tracking-[0.3em] uppercase text-white/30">
        ◆ {t('comingSoon.locked_notice')} ◆
      </p>
    </div>
  </div>

  <!-- Animated scroll cue -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 reveal">
    <div class="w-6 h-10 rounded-full border border-white/20 flex items-start justify-center p-1.5">
      <div class="w-1 h-2 rounded-full bg-gold-300/60 animate-bounce"></div>
    </div>
  </div>
</section>

<BetaSignup />
