---
import { getCollection } from 'astro:content';
import { useTranslations, getLangFromUrl, getLocalizedPath } from '../i18n/ui';
import { SKILL_CATEGORIES } from '../content/config';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const all = await getCollection('skills', ({ data }) => data.lang === lang && !data.draft);
const skills = all.sort((a, b) => {
  const orderDiff = a.data.order - b.data.order;
  return orderDiff !== 0 ? orderDiff : a.data.name.localeCompare(b.data.name);
});

const slugFor = (id: string) => id.replace(/^[^/]+\//, '').replace(/\.(md|mdx)$/, '');

const factionStyle = (f: string) =>
  f === 'angel'
    ? 'border-angel-500/30 text-angel-300'
    : f === 'demon'
      ? 'border-demon-500/30 text-demon-300'
      : 'border-white/15 text-white/60';

const allFilter = { value: 'all', label: t('skills.filter_all') };
const catFilters = SKILL_CATEGORIES.map((c) => ({
  value: c,
  label: t(`skill.${c}` as any),
}));
const filters = [allFilter, ...catFilters];
---

<section class="pt-32 pb-24">
  <div class="container-x">
    <a
      href={getLocalizedPath(lang, '/univers/')}
      class="text-sm font-display tracking-widest uppercase text-gold-300 hover:text-gold-500 transition-colors"
    >
      ← {t('universe.eyebrow')}
    </a>
    <p class="eyebrow mt-8">{t('skills.eyebrow')}</p>
    <h1 class="mt-4 text-4xl sm:text-5xl text-white">{t('skills.title')}</h1>
    <p class="mt-4 max-w-2xl text-white/70">{t('skills.lead')}</p>

    <div id="skill-filters" class="mt-10 flex flex-wrap gap-2">
      {
        filters.map((f) => (
          <button
            type="button"
            class="filter-pill text-xs font-display tracking-widest uppercase px-4 py-2 rounded-full border border-white/10 text-white/60 hover:border-gold-300/60 hover:text-gold-300 transition-all data-[active=true]:border-gold-300 data-[active=true]:text-gold-300 data-[active=true]:bg-gold-500/10"
            data-filter={f.value}
            data-active={f.value === 'all' ? 'true' : 'false'}
          >
            {f.label}
          </button>
        ))
      }
    </div>

    {
      skills.length === 0 ? (
        <p class="mt-16 text-white/40 italic">{t('skills.empty')}</p>
      ) : (
        <div id="skill-grid" class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {skills.map((s) => (
            <a
              href={getLocalizedPath(lang, `/univers/competences/${slugFor(s.id)}/`)}
              class="skill-card group rounded-xl border border-white/10 bg-ink-800/40 overflow-hidden hover:border-gold-500/40 transition-all hover:-translate-y-1 duration-300 block"
              data-category={s.data.category}
            >
              {s.data.cover ? (
                <div class="aspect-[4/3] overflow-hidden bg-ink-900">
                  <img
                    src={s.data.cover}
                    alt={s.data.name}
                    loading="lazy"
                    class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
              ) : (
                <div class="aspect-[4/3] bg-gradient-to-br from-ink-700 to-ink-900 border-b border-white/5 flex items-center justify-center">
                  <span class="text-5xl text-white/10 font-display">✺</span>
                </div>
              )}
              <div class="p-6">
                <div class="flex items-center justify-between gap-3">
                  <span class="inline-block text-[10px] tracking-[0.3em] uppercase px-2 py-1 rounded border border-white/10 text-white/60 font-display">
                    {t(`skill.${s.data.category}` as any)}
                  </span>
                  <span
                    class:list={[
                      'inline-block text-[10px] tracking-[0.3em] uppercase px-2 py-1 rounded border font-display',
                      factionStyle(s.data.faction),
                    ]}
                  >
                    {t(`faction.${s.data.faction}` as any)}
                  </span>
                </div>
                <h2 class="mt-4 text-xl text-white group-hover:text-gold-300 transition-colors font-display">
                  {s.data.name}
                </h2>
                <p class="mt-3 text-white/65 text-sm leading-relaxed line-clamp-3">{s.data.summary}</p>
                {s.data.requiredLevel > 0 && (
                  <p class="mt-4 text-[10px] font-display tracking-widest uppercase text-white/40">
                    {t('skills.required_level')}: <span class="text-white/70">{s.data.requiredLevel}</span>
                  </p>
                )}
              </div>
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('#skill-filters .filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('.skill-card');

  filters.forEach((pill) => {
    pill.addEventListener('click', () => {
      const value = pill.dataset.filter || 'all';
      filters.forEach((p) => p.setAttribute('data-active', p === pill ? 'true' : 'false'));
      cards.forEach((card) => {
        const match = value === 'all' || card.dataset.category === value;
        card.style.display = match ? '' : 'none';
      });
    });
  });
</script>
