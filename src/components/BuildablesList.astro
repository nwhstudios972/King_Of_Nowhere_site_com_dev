---
import { getCollection } from 'astro:content';
import { useTranslations, getLangFromUrl, getLocalizedPath } from '../i18n/ui';
import { BUILD_CATEGORIES } from '../content/config';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const all = await getCollection('buildables', ({ data }) => data.lang === lang && !data.draft);
const buildables = all.sort((a, b) => a.data.order - b.data.order);

const slugFor = (id: string) => id.replace(/^[^/]+\//, '').replace(/\.(md|mdx)$/, '');

const factionClass = (f: string) =>
  f === 'angel'
    ? 'border-angel-500/30 text-angel-300'
    : f === 'demon'
      ? 'border-demon-500/30 text-demon-300'
      : 'border-white/15 text-white/60';
---

<section class="pt-32 pb-24">
  <div class="container-x">
    <a
      href={getLocalizedPath(lang, '/univers/')}
      class="text-sm font-display tracking-widest uppercase text-gold-300 hover:text-gold-500 transition-colors"
    >
      ← {t('universe.eyebrow')}
    </a>
    <p class="eyebrow mt-8">{t('build.eyebrow')}</p>
    <h1 class="mt-4 text-4xl sm:text-5xl text-white">{t('build.title')}</h1>
    <p class="mt-4 max-w-2xl text-white/70 leading-relaxed">{t('build.lead')}</p>

    {
      buildables.length === 0 ? (
        <p class="mt-16 text-white/40 italic">{t('build.empty')}</p>
      ) : (
        <>
          <nav class="mt-12 flex flex-wrap gap-2" data-filter-bar>
            <button
              type="button"
              data-filter="all"
              class="filter-pill is-active text-xs tracking-widest uppercase font-display px-4 py-2 rounded-full border border-gold-500/40 text-gold-300 hover:border-gold-300 transition-colors"
            >
              {t('build.filter_all')}
            </button>
            {BUILD_CATEGORIES.map((cat) => (
              <button
                type="button"
                data-filter={cat}
                class="filter-pill text-xs tracking-widest uppercase font-display px-4 py-2 rounded-full border border-white/15 text-white/65 hover:border-white/40 hover:text-white transition-colors"
              >
                {t(`build_cat.${cat}` as any)}
              </button>
            ))}
          </nav>

          <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-build-grid>
            {buildables.map((b) => (
              <a
                href={getLocalizedPath(lang, `/univers/construire/${slugFor(b.id)}/`)}
                data-category={b.data.category}
                class="build-card group rounded-xl border border-white/10 bg-ink-800/40 overflow-hidden hover:border-gold-500/40 transition-all hover:-translate-y-1 duration-300 block"
              >
                {b.data.cover ? (
                  <div class="aspect-[4/3] overflow-hidden bg-ink-900">
                    <img
                      src={b.data.cover}
                      alt={b.data.name}
                      loading="lazy"
                      class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
                    />
                  </div>
                ) : (
                  <div class="aspect-[4/3] bg-gradient-to-br from-ink-700 to-ink-900 border-b border-white/5 flex items-center justify-center">
                    <span class="text-5xl text-white/10 font-display">⊞</span>
                  </div>
                )}
                <div class="p-6">
                  <div class="flex flex-wrap gap-2">
                    <span class="inline-block text-[10px] tracking-[0.3em] uppercase px-2 py-1 rounded border border-white/15 text-white/60 font-display">
                      {t(`build_cat.${b.data.category}` as any)}
                    </span>
                    {b.data.faction !== 'neutral' && (
                      <span
                        class:list={[
                          'inline-block text-[10px] tracking-[0.3em] uppercase px-2 py-1 rounded border font-display',
                          factionClass(b.data.faction),
                        ]}
                      >
                        {t(`faction.${b.data.faction}` as any)}
                      </span>
                    )}
                  </div>
                  <h2 class="mt-4 text-2xl text-white group-hover:text-gold-300 transition-colors font-display">
                    {b.data.name}
                  </h2>
                  {b.data.tagline && (
                    <p class="mt-3 text-white/65 italic text-sm">{b.data.tagline}</p>
                  )}
                </div>
              </a>
            ))}
          </div>
        </>
      )
    }
  </div>
</section>

<script>
  const bar = document.querySelector<HTMLElement>('[data-filter-bar]');
  const cards = document.querySelectorAll<HTMLElement>('.build-card');
  if (bar) {
    bar.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest<HTMLButtonElement>('button[data-filter]');
      if (!btn) return;
      const filter = btn.dataset.filter;
      bar.querySelectorAll('button[data-filter]').forEach((b) => {
        b.classList.remove('is-active', 'border-gold-500/40', 'text-gold-300');
        b.classList.add('border-white/15', 'text-white/65');
      });
      btn.classList.add('is-active', 'border-gold-500/40', 'text-gold-300');
      btn.classList.remove('border-white/15', 'text-white/65');
      cards.forEach((c) => {
        const cat = c.dataset.category;
        c.style.display = !filter || filter === 'all' || cat === filter ? '' : 'none';
      });
    });

    const hash = window.location.hash.replace(/^#/, '');
    if (hash) {
      const match = bar.querySelector<HTMLButtonElement>(`button[data-filter="${hash}"]`);
      if (match) match.click();
    }
  }
</script>
