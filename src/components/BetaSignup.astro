---
import { useTranslations, getLangFromUrl } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="beta" class="section relative overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[100vw] h-[60vh] rounded-full opacity-30 blur-3xl"
      style="background: radial-gradient(circle, rgba(200,154,58,0.25) 0%, transparent 60%);"
    ></div>
  </div>

  <div class="container-x">
    <div class="max-w-2xl mx-auto text-center">
      <p class="eyebrow reveal">{t('beta.eyebrow')}</p>
      <h2 class="reveal mt-4 text-4xl sm:text-5xl text-white leading-tight">
        {t('beta.title')}
      </h2>
      <p class="reveal mt-6 text-lg text-white/70 leading-relaxed">
        {t('beta.lead')}
      </p>

      <form
        id="beta-form"
        class="reveal mt-12 text-left space-y-5"
        data-lang={lang}
        data-msg-success-title={t('beta.success_title')}
        data-msg-success-text={t('beta.success_text')}
        data-msg-error-generic={t('beta.error_generic')}
        data-msg-error-duplicate={t('beta.error_duplicate')}
        data-msg-error-invalid={t('beta.error_invalid')}
        data-msg-submit={t('beta.submit')}
        data-msg-submitting={t('beta.submitting')}
        novalidate
      >
        <div>
          <label for="email" class="block text-sm text-white/70 mb-2 font-display tracking-widest uppercase">
            {t('beta.email_label')}
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder={t('beta.email_placeholder')}
            class="w-full px-4 py-3 rounded-md bg-ink-700/60 border border-white/10 text-white placeholder:text-white/30 focus:border-gold-300 focus:outline-none focus:ring-2 focus:ring-gold-500/30 transition-all"
          />
        </div>

        <fieldset>
          <legend class="block text-sm text-white/70 mb-3 font-display tracking-widest uppercase">
            {t('beta.side_label')}
          </legend>
          <div class="grid grid-cols-3 gap-3">
            <label class="cursor-pointer">
              <input type="radio" name="side" value="undecided" class="sr-only peer" checked />
              <span class="block text-center px-3 py-3 rounded-md border border-white/10 text-white/60 text-sm peer-checked:border-gold-300 peer-checked:bg-gold-500/10 peer-checked:text-gold-300 hover:border-white/30 transition-all">
                {t('beta.side_undecided')}
              </span>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="side" value="angel" class="sr-only peer" />
              <span class="block text-center px-3 py-3 rounded-md border border-white/10 text-white/60 text-sm peer-checked:border-angel-300 peer-checked:bg-angel-500/10 peer-checked:text-angel-300 hover:border-white/30 transition-all">
                {t('beta.side_angel')}
              </span>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="side" value="demon" class="sr-only peer" />
              <span class="block text-center px-3 py-3 rounded-md border border-white/10 text-white/60 text-sm peer-checked:border-demon-300 peer-checked:bg-demon-500/10 peer-checked:text-demon-300 hover:border-white/30 transition-all">
                {t('beta.side_demon')}
              </span>
            </label>
          </div>
        </fieldset>

        <button type="submit" class="btn-primary w-full" data-submit-btn>
          {t('beta.submit')}
        </button>

        <p class="text-xs text-white/40 text-center" data-privacy>{t('beta.privacy')}</p>
        <p class="hidden text-sm text-center" data-message></p>
      </form>

      <div id="beta-success" class="hidden reveal mt-12 rounded-xl border border-gold-500/40 bg-gold-500/10 p-8">
        <h3 class="text-2xl text-gold-300 font-display">{t('beta.success_title')}</h3>
        <p class="mt-3 text-white/80">{t('beta.success_text')}</p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('beta-form') as HTMLFormElement | null;
  const success = document.getElementById('beta-success');
  if (form && success) {
    const btn = form.querySelector<HTMLButtonElement>('[data-submit-btn]');
    const msgEl = form.querySelector<HTMLParagraphElement>('[data-message]');
    const privacy = form.querySelector<HTMLParagraphElement>('[data-privacy]');

    const lang = form.dataset.lang || 'fr';
    const msgs = {
      successTitle: form.dataset.msgSuccessTitle || '',
      successText: form.dataset.msgSuccessText || '',
      errorGeneric: form.dataset.msgErrorGeneric || '',
      errorDuplicate: form.dataset.msgErrorDuplicate || '',
      errorInvalid: form.dataset.msgErrorInvalid || '',
      submit: form.dataset.msgSubmit || '',
      submitting: form.dataset.msgSubmitting || '',
    };

    function showError(text: string) {
      if (!msgEl) return;
      msgEl.textContent = text;
      msgEl.classList.remove('hidden', 'text-gold-300');
      msgEl.classList.add('text-demon-300');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!btn) return;

      const data = new FormData(form);
      const email = String(data.get('email') || '').trim();
      const side = String(data.get('side') || 'undecided');

      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showError(msgs.errorInvalid);
        return;
      }

      btn.disabled = true;
      btn.textContent = msgs.submitting;
      msgEl?.classList.add('hidden');

      try {
        const res = await fetch('/api/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, side, locale: lang }),
        });

        if (res.ok) {
          form.classList.add('hidden');
          privacy?.classList.add('hidden');
          success.classList.remove('hidden');
          return;
        }

        const body = await res.json().catch(() => ({}));
        if (body?.error === 'duplicate') {
          showError(msgs.errorDuplicate);
        } else if (body?.error === 'invalid') {
          showError(msgs.errorInvalid);
        } else {
          showError(msgs.errorGeneric);
        }
      } catch {
        showError(msgs.errorGeneric);
      } finally {
        btn.disabled = false;
        btn.textContent = msgs.submit;
      }
    });
  }
</script>
