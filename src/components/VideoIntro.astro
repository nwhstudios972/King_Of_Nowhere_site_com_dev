---
import { useTranslations, getLangFromUrl } from '../i18n/ui';
import VideoPlayer from './VideoPlayer.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const videoSrc = lang === 'en' ? '/videos/intro-univers-en.mp4' : '/videos/intro-univers.mp4';
const posterSrc = lang === 'en' ? '/videos/intro-univers-en-poster.jpg' : '/videos/intro-univers-poster.jpg';
---

<section class="relative py-16 sm:py-24 overflow-hidden">
  <div
    class="absolute inset-0 -z-10"
    style="background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(200,154,58,0.08) 0%, transparent 70%);"
  ></div>

  <div class="container-x">
    <div class="max-w-5xl mx-auto text-center mb-8 sm:mb-12">
      <p class="eyebrow reveal">{t('videoIntro.eyebrow')}</p>
      <h2
        class="reveal mt-4 font-display text-3xl sm:text-4xl lg:text-5xl tracking-wide text-white"
      >
        {t('videoIntro.title')}
      </h2>
    </div>

    <div class="reveal max-w-5xl mx-auto">
      <VideoPlayer src={videoSrc} poster={posterSrc} ariaLabel={t('videoIntro.title')} loop />
    </div>
  </div>
</section>
