---
import { useTranslations, getLangFromUrl } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const errorCode = Astro.url.searchParams.get('error');
const errorMap: Record<string, string> = {
  denied: t('adminLogin.error_denied'),
  invalid: t('adminLogin.error_invalid'),
  config: t('adminLogin.error_config'),
  rate: t('adminLogin.error_rate'),
};
const errorMsg = errorCode ? errorMap[errorCode] ?? t('adminLogin.error_denied') : null;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden py-24">
  <div class="absolute inset-0 -z-30 starfield opacity-40"></div>
  <div
    class="absolute -top-32 -left-32 w-[500px] h-[500px] rounded-full blur-3xl opacity-50 -z-10"
    style="background: radial-gradient(circle, rgba(91,141,239,0.25) 0%, transparent 65%);"
  ></div>
  <div
    class="absolute -bottom-32 -right-32 w-[500px] h-[500px] rounded-full blur-3xl opacity-50 -z-10"
    style="background: radial-gradient(circle, rgba(216,58,26,0.22) 0%, transparent 65%);"
  ></div>

  <div class="container-x">
    <div class="max-w-md mx-auto">
      <div class="rounded-2xl border border-white/10 bg-ink-800/50 backdrop-blur-xl p-8 sm:p-10 shadow-2xl">
        <p class="eyebrow">{t('adminLogin.eyebrow')}</p>
        <h1 class="mt-3 text-3xl sm:text-4xl font-display text-white leading-tight">
          {t('adminLogin.title')}
        </h1>
        <p class="mt-3 text-sm text-white/60">{t('adminLogin.lead')}</p>

        {errorMsg && (
          <p class="mt-6 rounded-md border border-demon-500/40 bg-demon-500/10 px-4 py-3 text-sm text-demon-300">
            {errorMsg}
          </p>
        )}

        <form method="POST" action="/api/admin/login" class="mt-8 space-y-5">
          <input type="hidden" name="locale" value={lang} />
          <div>
            <label for="email" class="block text-sm text-white/70 mb-2 font-display tracking-widest uppercase">
              {t('adminLogin.email_label')}
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="w-full px-4 py-3 rounded-md bg-ink-900/60 border border-white/10 text-white placeholder:text-white/30 focus:border-gold-300 focus:outline-none focus:ring-2 focus:ring-gold-500/30 transition-all"
            />
          </div>

          <div>
            <label for="password" class="block text-sm text-white/70 mb-2 font-display tracking-widest uppercase">
              {t('adminLogin.password_label')}
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="current-password"
              class="w-full px-4 py-3 rounded-md bg-ink-900/60 border border-white/10 text-white placeholder:text-white/30 focus:border-gold-300 focus:outline-none focus:ring-2 focus:ring-gold-500/30 transition-all"
            />
          </div>

          <button type="submit" class="btn-primary w-full">
            {t('adminLogin.submit')}
          </button>
        </form>

        <div class="mt-6 text-center">
          <a href={`/${lang}/`} class="text-xs text-white/40 hover:text-white/70 tracking-wider transition-colors">
            {t('adminLogin.back')}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
